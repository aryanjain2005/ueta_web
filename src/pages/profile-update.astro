---
import Layout from "@layouts/Layout.astro";
import { drizzle } from "drizzle-orm/d1";
import { eq } from "drizzle-orm";
import * as s from "db/schema";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const { env } = Astro.locals.runtime;
const db = drizzle(env.DB, { schema: s });

const userData = await db.query.users.findFirst({
  where: eq(s.users.id, parseInt(user.id, 10)),
  with: { business: { with: { contacts: true } } },
});

if (!userData?.business) return Astro.redirect("/");
const b = userData.business;

const cMap = b.contacts.reduce(
  (acc, c) => ({ ...acc, [c.type]: c.value }),
  {} as any,
);
const shopImages = b.shopImages?.split(",").filter(Boolean) || [];
---

<Layout title="Edit Business Profile">
  <main class="min-h-screen bg-[#F8F9FD] p-3 sm:p-6 md:p-10 font-gr">
    <div
      class="max-w-5xl mx-auto bg-white rounded-[1.5rem] sm:rounded-[2.5rem] p-5 sm:p-10 md:p-14 shadow-sm border border-gray-100">
      <form id="profile-update-form" class="space-y-6 sm:space-y-10">
        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-4 sm:gap-y-8">
          <div class="md:row-span-2 flex flex-col items-center gap-2">
            <div
              class="relative w-28 h-28 sm:w-32 sm:h-32 md:w-44 md:h-44 group">
              <img
                src={b.image || "/imgg.png"}
                class="w-full h-full rounded-2xl sm:rounded-3xl object-cover border-4 border-[#F3F6F9] shadow-sm"
                id="main-preview"
              />
              <input
                type="file"
                id="image-upload"
                name="imageFile"
                class="hidden"
                accept="image/*"
              />
              <input
                type="hidden"
                name="image"
                id="profile-image-value"
                value={b.image || "/imgg.png"}
              />
            </div>

            <div class="flex gap-4">
              <label
                for="image-upload"
                class="text-[9px] sm:text-[10px] font-bold text-[#7D57B3] uppercase tracking-widest cursor-pointer hover:underline">
                Change Photo
              </label>
              <button
                type="button"
                id="delete-profile-photo"
                class="text-[9px] sm:text-[10px] font-bold text-red-500 uppercase tracking-widest hover:underline">
                Delete Photo
              </button>
            </div>
          </div>

          <div class="space-y-1">
            <div class="flex justify-between items-center">
              <label
                class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em]"
                >Full Name</label
              >
              <span
                class="text-[9px] sm:text-[10px] text-gray-400"
                id="name-count">0/25</span
              >
            </div>
            <input
              type="text"
              name="name"
              id="name-input"
              value={b.name}
              maxlength="25"
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none focus:ring-2 focus:ring-[#7D57B3]"
            />
          </div>

          <div class="space-y-1">
            <div class="flex justify-between items-center">
              <label
                class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em]"
                >Shop Name*</label
              >
              <span
                class="text-[9px] sm:text-[10px] text-gray-400"
                id="shop-count">0/43</span
              >
            </div>
            <input
              type="text"
              name="shopName"
              id="shop-input"
              value={b.shopName}
              maxlength="43"
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none"
              required
            />
          </div>

          <div class="md:col-span-2 space-y-1">
            <div class="flex justify-between items-center">
              <label
                class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em]"
                >Business Address</label
              >
              <span
                class="text-[9px] sm:text-[10px] text-gray-400"
                id="address-count">0/130</span
              >
            </div>
            <textarea
              name="address"
              id="address-input"
              maxlength="130"
              rows="2"
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none resize-none"
              >{b.address}</textarea
            >
          </div>

          <div class="space-y-1">
            <label
              class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400"
              >Phone Number (10 Digits)</label
            >
            <input
              type="tel"
              name="phone"
              value={cMap.phone || ""}
              pattern="[0-9]{10}"
              maxlength="10"
              placeholder="9876543210"
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none num-only"
            />
          </div>

          <div class="space-y-1">
            <label
              class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400"
              >WhatsApp Number (10 Digits)</label
            >
            <input
              type="tel"
              name="whatsapp"
              value={cMap.whatsapp || ""}
              pattern="[0-9]{10}"
              maxlength="10"
              placeholder="9876543210"
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none num-only"
            />
          </div>

          <div class="space-y-1">
            <label
              class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em]"
              >Mail ID</label
            >
            <input
              type="email"
              name="email"
              value={cMap.email || ""}
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none"
            />
          </div>

          <div class="space-y-1">
            <label
              class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em]"
              >Location URL</label
            >
            <input
              type="text"
              name="location"
              value={b.location || ""}
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none"
            />
          </div>

          <div class="space-y-1">
            <label
              class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em]"
              >Facebook ID</label
            >
            <input
              type="text"
              name="facebook"
              value={cMap.facebook || ""}
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none"
            />
          </div>

          <div class="space-y-1">
            <label
              class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em]"
              >Instagram ID</label
            >
            <input
              type="text"
              name="instagram"
              value={cMap.instagram || ""}
              class="w-full bg-[#F3F6F9] border-none rounded-xl sm:rounded-2xl p-3 sm:p-4 text-sm sm:text-base outline-none"
            />
          </div>
        </div>

        <div class="pt-6 sm:pt-8 border-t border-gray-100">
          <label
            class="text-[10px] sm:text-[11px] font-black uppercase text-gray-400 tracking-[0.2em] block mb-4 sm:mb-6"
            >Shop Images Gallery</label
          >
          <div
            class="grid grid-cols-2 xxs:grid-cols-3 xs:grid-cols-4 gap-3 sm:gap-6"
            id="gallery-container">
            {
              shopImages.map((img) => (
                <div class="relative aspect-square group rounded-2xl sm:rounded-[2rem] overflow-hidden border shadow-sm">
                  <img src={img} class="w-full h-full object-cover" />
                  <button
                    type="button"
                    class="delete-img absolute top-2 right-2 bg-white text-red-600 p-1.5 rounded-full shadow-md hover:scale-110 transition-all z-10">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18" />
                      <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                  </button>
                  <input type="hidden" name="shopImages" value={img} />
                </div>
              ))
            }
            <label
              class="aspect-square flex flex-col items-center justify-center border-2 border-dashed rounded-2xl sm:rounded-[2rem] cursor-pointer hover:bg-gray-50 transition border-gray-200">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 sm:h-10 sm:w-10 text-gray-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4v16m8-8H4"></path>
              </svg>
              <input type="file" id="add-gallery-img" class="hidden" multiple />
            </label>
          </div>
        </div>

        <button
          type="submit"
          class="w-full bg-[#7D57B3] text-white py-4 sm:py-5 rounded-xl sm:rounded-[2rem] font-bold text-base sm:text-lg shadow-xl shadow-purple-100 hover:scale-[1.01] transition-all uppercase tracking-widest">
          SAVE ALL CHANGES
        </button>
      </form>
    </div>
  </main>
</Layout>

<script>
  const setupCounter = (id, countId, max) => {
    const el = document.getElementById(id) as HTMLInputElement;
    const cnt = document.getElementById(countId);
    if (!el || !cnt) return;
    const up = () => {
      cnt.textContent = `${el.value.length}/${max}`;
    };
    el.addEventListener("input", up);
    up();
  };

  setupCounter("name-input", "name-count", 25);
  setupCounter("shop-input", "shop-count", 43);
  setupCounter("address-input", "address-count", 130);

  document.querySelectorAll(".num-only").forEach((i) => {
    i.addEventListener(
      "input",
      (e: any) => (e.target.value = e.target.value.replace(/[^0-9]/g, "")),
    );
  });

  // Profile Image Preview/Logic
  const imageUpload = document.getElementById(
    "image-upload",
  ) as HTMLInputElement;
  const mainPreview = document.getElementById(
    "main-preview",
  ) as HTMLImageElement;
  const profileImageValue = document.getElementById(
    "profile-image-value",
  ) as HTMLInputElement;
  const deleteProfileBtn = document.getElementById("delete-profile-photo");

  imageUpload?.addEventListener("change", (e: any) => {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = (re) => {
        mainPreview.src = re.target?.result as string;
      };
      reader.readAsDataURL(file);
    }
  });

  deleteProfileBtn?.addEventListener("click", () => {
    const fallback = "/media/person1.png";
    mainPreview.src = fallback;
    profileImageValue.value = fallback; // Tells server to save fallback URL
    imageUpload.value = ""; // Clears selected file
  });

  // Gallery Management
  document.addEventListener("click", (e: any) => {
    const delBtn = e.target.closest(".delete-img");
    if (delBtn) {
      delBtn.closest(".relative").remove();
    }
  });

  // Handle Save with Multi-part Data
  const form = document.getElementById(
    "profile-update-form",
  ) as HTMLFormElement;
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Use FormData instead of JSON to support file uploads
    const formData = new FormData(form);

    // Manually add gallery files from the hidden input if they exist
    const galleryInput = document.getElementById(
      "add-gallery-img",
    ) as HTMLInputElement;
    if (galleryInput?.files) {
      for (let i = 0; i < galleryInput.files.length; i++) {
        formData.append("newGalleryFiles", galleryInput.files[i]);
      }
    }

    // Submit button loading state (optional but recommended)
    const btn = form.querySelector('button[type="submit"]');
    if (btn) btn.textContent = "UPLOADING...";

    const res = await fetch("/api/business/update", {
      method: "POST",
      body: formData, // No 'Content-Type' header needed; browser sets boundary
    });

    if (res.ok) {
      alert("Profile & Images Updated!");
      window.location.reload();
    } else {
      alert("Update failed. Please try again.");
      if (btn) btn.textContent = "SAVE ALL CHANGES";
    }
  });
</script>
