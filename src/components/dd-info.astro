---
// src/components/dd-info.astro
import ContactButton from "./contact-button";
import ScrollView from "./ui/scroll-view.astro";

interface Props {
  entry: any;
  isOwner?: boolean;
}

const { entry, isOwner = false } = Astro.props;
---

<section class="px-2 xs:px-6 md:px-8 py-6 md:mb-8 relative">
  <div class="flex flex-row items-center gap-4 xs:gap-10 md:gap-12 lg:gap-16">
    <!-- LEFT: photo -->
    <div
      class="flex flex-col items-center gap-2
        w-[160px]
        md:w-[260px]
        lg:w-[300px]
        flex-shrink-0">
      <img
        src={entry.image || "/imgg.png"}
        alt={entry.name}
        class="w-[130px] h-[130px]
      xs:w-[160px] xs:h-[160px]
      md:w-[200px] md:h-[200px]
      lg:w-[220px] lg:h-[220px]
    rounded-2xl
    object-cover
    shadow-[10px_10px_25px_rgba(0,0,0,0.8)]
    bg-white"
      />
      <p
        class="font-semibold w-full text-sm xs:text-lg md:text-2xl lg:text-3xl text-center pt-4">
        {entry.name}
      </p>
    </div>

    <!-- RIGHT: details + contacts + map -->
    <div
      class="flex flex-col justify-between
  items-center
  gap-2 xs:gap-4
  text-sm xs:text-base
  w-full md:w-auto
  max-w-md
  text-center
  break-words
  overflow-hidden">
      <div>
        <p class="text-lg md:text-xl lg:text-3xl pb-1 xs:pb-2 font-bold">
          {entry.shopName}
        </p>
        {
          entry.address && (
            <p class="leading-snug sm:text-left text-xs sm:text-sm md:text-base text-gray-600">
              {entry.address}
            </p>
          )
        }
      </div>

      <div class="flex flex-wrap items-center justify-center">
        {
          entry.contact.length > 0 && (
            <div class="flex flex-wrap items-center justify-center gap-2 pt-1 sm:text-sm md:text-lg lg:text-xl">
              <div class="flex flex-row flex-wrap justify-center gap-2">
                {entry.contact.map((contact) => (
                  <ContactButton contact={contact} />
                ))}
              </div>
              {entry.location && (
                <a
                  href={entry.location}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-1 text-xs sm:text-sm md:text-base text-black hover:underline"
                />
              )}
            </div>
          )
        }
      </div>
      {
        isOwner && (
          <div class="pt-2 border-t border-gray-100 sm:border-none">
            <a
              href="/profile-update"
              class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-gray-500 hover:text-black transition">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
                />
              </svg>
              Edit Profile
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>
{
  entry.shopImages && entry.shopImages.length > 0 && (
    <ScrollView class="mx-auto" gap="gap-4">
      {entry.shopImages.map((image) => (
        <div class="h-[100px] sm:h-[160px] min-w-fit flex-shrink-0">
          <img
            src={image}
            class="rounded-md h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      ))}
    </ScrollView>
  )
}
